    "fig, (ax_dk, ax_nor) = plt.subplots(1, 2, figsize=(18, 6), sharey=True)\n",
    "cmap = plt.colormaps['tab10']\n",
    "\n",
    "# Define custom ordered list for scenario lines\n",
    "scenario_order = ['Base', '1', '2', '3', '4']\n",
